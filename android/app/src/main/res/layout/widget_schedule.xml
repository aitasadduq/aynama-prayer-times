<?xml version="1.0" encoding="utf-8"?>
<!-- Sample text below is placeholder for the drawer previewLayout; overwritten at runtime. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    tools:ignore="HardcodedText">

    <!-- Top ~1/4 : dates — ink band, text parchment, centered -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:background="@drawable/widget_section_top"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <TextView
            android:id="@+id/widget_gregorian"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/ibm_plex_sans"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Sun, Jun 15"
            android:textColor="@color/aynama_parchment"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/widget_hijri"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/ibm_plex_sans"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="19 Dhu al-Ḥijjah 1446"
            android:textColor="@color/aynama_parchment_muted"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Middle : six prayer times, evenly distributed -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="6"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp">

        <LinearLayout style="@style/WidgetListRow">
            <TextView android:id="@+id/widget_row_1_name" style="@style/WidgetListName" android:text="Fajr" />
            <TextView android:id="@+id/widget_row_1_time" style="@style/WidgetListTime" android:text="03:09" />
        </LinearLayout>

        <LinearLayout style="@style/WidgetListRow">
            <TextView android:id="@+id/widget_row_2_name" style="@style/WidgetListName" android:text="Sunrise" />
            <TextView android:id="@+id/widget_row_2_time" style="@style/WidgetListTime" android:text="04:43" />
        </LinearLayout>

        <LinearLayout style="@style/WidgetListRow">
            <TextView android:id="@+id/widget_row_3_name" style="@style/WidgetListName" android:text="Dhuhr" />
            <TextView android:id="@+id/widget_row_3_time" style="@style/WidgetListTime" android:text="13:01" />
        </LinearLayout>

        <LinearLayout style="@style/WidgetListRow">
            <TextView android:id="@+id/widget_row_4_name" style="@style/WidgetListName" android:text="Asr" />
            <TextView android:id="@+id/widget_row_4_time" style="@style/WidgetListTime" android:text="17:14" />
        </LinearLayout>

        <LinearLayout style="@style/WidgetListRow">
            <TextView android:id="@+id/widget_row_5_name" style="@style/WidgetListName" android:text="Maghrib" />
            <TextView android:id="@+id/widget_row_5_time" style="@style/WidgetListTime" android:text="21:18" />
        </LinearLayout>

        <LinearLayout style="@style/WidgetListRow">
            <TextView android:id="@+id/widget_row_6_name" style="@style/WidgetListName" android:text="Isha" />
            <TextView android:id="@+id/widget_row_6_time" style="@style/WidgetListTime" android:text="22:52" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom : profile — ink band, text parchment, centered, pinned to bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_section_bottom"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <TextView
            android:id="@+id/widget_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/ibm_plex_sans"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Home"
            android:textColor="@color/aynama_parchment_muted"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
