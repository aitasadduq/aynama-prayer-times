<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_next_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="@font/fraunces"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/aynama_saffron"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Chronometer
            android:id="@+id/widget_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/fraunces"
            android:includeFontPadding="false"
            android:textColor="@color/aynama_ink"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/widget_schedule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="3">

        <TextView android:id="@+id/widget_row_1_name" style="@style/WidgetScheduleName" />
        <TextView android:id="@+id/widget_row_1_time" style="@style/WidgetScheduleTime" />
        <TextView android:id="@+id/widget_row_2_name" style="@style/WidgetScheduleName" />
        <TextView android:id="@+id/widget_row_2_time" style="@style/WidgetScheduleTime" />
        <TextView android:id="@+id/widget_row_3_name" style="@style/WidgetScheduleName" />
        <TextView android:id="@+id/widget_row_3_time" style="@style/WidgetScheduleTime" />
        <TextView android:id="@+id/widget_row_4_name" style="@style/WidgetScheduleName" />
        <TextView android:id="@+id/widget_row_4_time" style="@style/WidgetScheduleTime" />
        <TextView android:id="@+id/widget_row_5_name" style="@style/WidgetScheduleName" />
        <TextView android:id="@+id/widget_row_5_time" style="@style/WidgetScheduleTime" />
        <TextView android:id="@+id/widget_row_6_name" style="@style/WidgetScheduleName" />
        <TextView android:id="@+id/widget_row_6_time" style="@style/WidgetScheduleTime" />
    </GridLayout>
</LinearLayout>
